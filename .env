# GitHub API — optional, increases rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=

# Ollama — uses container name when running via docker compose
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=codellama:7b-instruct

# Apache Kafka — uses container name when running via docker compose
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=ai-events

# Neon PostgreSQL — postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_RHlp2GCILq9U@ep-square-bird-ai3yx20c-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Per-user chat memory: last N questions+answers loaded from DB for context
CHAT_HISTORY_SIZE=10
